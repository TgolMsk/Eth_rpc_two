# ============================================================
# Ethereum RPC Service - Environment Configuration
# Copy this file to .env and modify as needed
# ============================================================

# ---------- Network ----------
# mainnet | sepolia | holesky
ETH_NETWORK=mainnet

# ---------- Data Paths ----------
GETH_DATA_DIR=/data/ethereum/geth
LIGHTHOUSE_DATA_DIR=/data/ethereum/lighthouse
JWT_SECRET_PATH=./jwt/jwt.hex

# ---------- Geth (Execution Client) ----------
GETH_IMAGE=ethereum/client-go:stable
GETH_HTTP_PORT=8545
GETH_WS_PORT=8546
GETH_AUTH_PORT=8551
GETH_P2P_PORT=30303
GETH_METRICS_PORT=6060
GETH_CACHE=4096
GETH_MAX_PEERS=50

# ---------- Lighthouse (Consensus Client) ----------
LIGHTHOUSE_IMAGE=sigp/lighthouse:latest
LIGHTHOUSE_HTTP_PORT=5052
LIGHTHOUSE_METRICS_PORT=5054
LIGHTHOUSE_P2P_PORT=9000
LIGHTHOUSE_CHECKPOINT_SYNC_URL=https://mainnet.checkpoint.sigp.io

# ---------- Nginx ----------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
RPC_RATE_LIMIT=30r/s
RPC_BURST=50
WS_RATE_LIMIT=10r/s

# ---------- Monitoring ----------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme_strong_password

# ---------- Health Check Service ----------
HEALTHCHECK_PORT=8080

# ---------- Server Resources ----------
# Recommended: at least 16GB RAM, 2TB NVMe SSD
# GETH_CACHE should be ~25% of total RAM in MB
