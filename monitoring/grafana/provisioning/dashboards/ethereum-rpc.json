{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Sync Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "eth_syncing",
          "legendFormat": "Syncing (0=synced)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "SYNCED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "SYNCING", "color": "yellow" } } }
          ],
          "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }] }
        },
        "overrides": []
      }
    },
    {
      "title": "Latest Block",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "eth_block_number",
          "legendFormat": "Block #"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "title": "Peer Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "eth_peer_count",
          "legendFormat": "Peers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 5, "color": "yellow" }, { "value": 20, "color": "green" }] }
        },
        "overrides": []
      }
    },
    {
      "title": "CL Sync Distance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "cl_sync_distance",
          "legendFormat": "Slots behind"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 3, "color": "yellow" }, { "value": 64, "color": "red" }] }
        },
        "overrides": []
      }
    },
    {
      "title": "Block Number Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "eth_block_number",
          "legendFormat": "Block #"
        }
      ]
    },
    {
      "title": "RPC Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(eth_rpc_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(eth_rpc_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(eth_rpc_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "title": "Health Check Results",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(eth_health_checks_total[5m])",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "title": "Geth Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"geth\"}",
          "legendFormat": "RSS"
        },
        {
          "expr": "go_memstats_alloc_bytes{job=\"geth\"}",
          "legendFormat": "Go Alloc"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ethereum", "rpc", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Ethereum RPC Service",
  "uid": "eth-rpc-dashboard"
}
